# Usuário administrador
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# JWT
JWT_TTL=8h
JWT_SECRET=dev-secret-change-me-min-32-chars-long!!

# Sistema de armazenamento (só vale em production / NODE_ENV=production):
# - `github` = produção (Vercel)
# - `fs` = filesystem sob data/
# Em development (next dev): sempre fs sob data-dev/ (DATA_BACKEND é ignorado).
# Popule data-dev: dev:restore:data (cópia de data/) | dev:reset:data (limpa) | dev:seed (reset + volume xlarge)
# Após copiar/seed produtos sem índice: npm run indices:rebuild|repair -- --data=data-dev
# Validar consistência: npm run indices:validate -- --data=data-dev
DATA_BACKEND=fs

# URL pública da aplicação
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Observabilidade de leitura (Fase 0 + Fase 5):
# - READ_METRICS=1 força coleta/log estruturado (filesRead, bytesRead, cache hit/miss,
#   indexHit, page, pageSize em listagens)
# - Em development o default é ligado; em production fica off até optar in
# - READ_METRICS_LOG=0 silencia o console mantendo a coleta ativa sob runWithReadMetrics
# - READ_ALERTS=0 silencia alertas LISTING_FILES_READ (>20) e LISTING_HTML_BYTES (>500KB)
# - READ_METRICS_DIAGNOSTICS=0 desliga GET /api/v1/admin/diagnostics/read-baseline
# Após seed/cópia sem índice: npm run indices:rebuild | indices:repair | indices:validate
# DoD global (Fase 6): npm run phase6:verify  (± --strict)
# READ_METRICS=1
# READ_METRICS_LOG=1
# READ_ALERTS=1
# READ_METRICS_DIAGNOSTICS=1

# Obrigatórios quando DATA_BACKEND=github
# GITHUB_TOKEN=
# GITHUB_OWNER=
# GITHUB_BRANCH=main
# GITHUB_REPO=pe-quente
